# Superapp environment
API_BASE_URL=http://localhost:8080/api/v1

# Optional: DuckDB path for scholarship queries (zero-coupling — omit to disable)
# DUCKDB_PATH=data/scholarships.duckdb

# Optional: SQLite path (defaults to data/superapp.db)
# SQLITE_PATH=data/superapp.db

# Optional: Beasiswa frontend directory (zero-coupling — omit to disable)
# BEASISWA_DIR=/path/to/beasiswa

# Optional: Server port (defaults to 8080)
# PORT=8080
