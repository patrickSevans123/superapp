# Superapp environment configuration
#
# Configuration is now passed at build time via --dart-define.
# The .env file is no longer used (it would be bundled into the web build).
#
# Development:
#   flutter run --dart-define=API_BASE_URL=http://localhost:8080/api/v1
#   (or just use the default — http://localhost:8080/api/v1)
#
# Web release build:
#   flutter build web --release --dart-define=API_BASE_URL=https://api.example.com/api/v1
#
# Android/iOS release build:
#   flutter build apk --release --dart-define=API_BASE_URL=https://api.example.com/api/v1
#
# Optional: OpenWeather API key for the Fashion module's weather-based OOTD suggestions.
# Without a key, the app falls back to mock Jakarta weather.
#   flutter run --dart-define=OPENWEATHER_API_KEY=your-openweather-key
