# ─── API Gateway Configuration ────────────────────────────────────────────────

# Server port (default: 8080)
PORT=8080

# JWT secret key (required — change to a strong random value in production)
JWT_SECRET=change-me-to-a-random-secret

# CORS allowed origins (comma-separated, no trailing slash)
# Default: http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# SQLite database path (default: data/superapp.db)
# SQLITE_PATH=data/superapp.db

# DuckDB path for scholarship queries (optional — omit to disable)
# DUCKDB_PATH=/path/to/scholarships.duckdb

# News parquet base directory (optional — enables local fallback for
# /api/v1/news* when the self-trade backend is down). Each subdirectory
# is a source name (bloomberg_english / bloomberg_technoz / reuters)
# containing <YYYY-MM>.parquet files.
# NEWS_PARQUET_DIR=/home/evans/Projects/self-trade/datasets/parquet/news

# Beasiswa frontend static directory (optional — omit to disable)
# BEASISWA_DIR=/path/to/beasiswa
